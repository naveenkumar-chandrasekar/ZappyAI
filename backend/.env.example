PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/zappy

JWT_SECRET=your-super-secret-jwt-key-change-in-production

# IANA timezone for task/reminder due times when the user does not specify one (matches UI)
USER_TIMEZONE=Asia/Kolkata

# APP_MODE controls LLM provider:
#   production  → Claude Agent SDK (requires ANTHROPIC_API_KEY)
#   development → Ollama via OpenAI-compatible API (requires Ollama running locally)
#   demo        → Groq (fast free-tier inference, requires GROQ_API_KEY)
APP_MODE=development

# Production: Anthropic API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

# Development: Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2

# Demo: Groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

WHATSAPP_TOKEN=your-whatsapp-bearer-token
WHATSAPP_PHONE_ID=your-whatsapp-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
