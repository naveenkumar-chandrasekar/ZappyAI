    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.8",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "libphonenumber-js": "^1.12.41",
    "node-cron": "^3.0.3",
    "openai": "^6.33.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "zod": "^3.23.8"
